print ("welcome to the tip calculator")
bill = float(input("how much was the total bill? "))
tip = int(input("how much would you like to tip 10, 12, or 15 "))
people = int(input("How many people split the bill? "))
totalbill = tip/100 * bill + bill
print (f"Your bill including tip is : {totalbill}" )
eachbill = round(totalbill / people, 2)
print (f"each person should pay {eachbill}")
